{
  "Log": {
    "Level": "{{ v2bx_log_level }}",
    "Output": ""
  },
  "Cores": [
    {
      "Type": "{{ v2bx_core }}",
      "Name": "{{ v2bx_core }}_core",
      "Log": {
        "Level": "{{ v2bx_log_level }}",
        "Timestamp": true
      },
      "NTP": {
        "Enable": false,
        "Server": "time.apple.com",
        "ServerPort": 0
      }
    }
  ],
  "Nodes": [
{% for protocol in v2bx_protocols %}
    {
      "Name": "{{ v2bx_node_name }}-{{ protocol }}",
      "Core": "{{ v2bx_core }}_core",
      "ApiHost": "{{ v2bx_api_host }}",
      "AutoRegister": {{ v2bx_auto_register | lower }},
      "AuthKey": "{{ v2bx_auth_key }}",
      "NodeName": "{{ v2bx_node_name }}",
      "NodeType": "{{ protocol }}",
      "CredentialFile": "{{ v2bx_credential_file }}",
      "HeartbeatInterval": {{ v2bx_heartbeat_interval }},
      "EnableSign": {{ v2bx_enable_sign | lower }},
      "EncryptCredential": {{ v2bx_encrypt_credential | lower }},
      "Timeout": 30,
      "ListenIP": "0.0.0.0",
      "SendIP": "0.0.0.0",
      "DeviceOnlineMinTraffic": 200,
      "MinReportTraffic": 0,
      "TCPFastOpen": false,
      "SniffEnabled": true,
      "CertConfig": {
        "CertMode": "{{ v2bx_cert_mode }}",
        "RejectUnknownSni": false,
        "CertDomain": "{{ v2bx_cert_domain }}",
        "CertFile": "",
        "KeyFile": "",
        "Provider": "cloudflare"
      }
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
}